# Copy to `.trade.env` and fill locally. Do not commit `.trade.env`.

POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137

# Exported from Polymarket Account -> Private key.
POLYMARKET_PRIVATE_KEY=0x...

# Polymarket Wallet Address / API wallet address shown in settings.
POLYMARKET_FUNDER_ADDRESS=0xfffbAA1616CE86d4a62e614e92ca6565198FC2F3

# Use 0 if the exported private key address equals the funder address.
# If not, verify the Polymarket wallet mode before trading.
POLYMARKET_SIGNATURE_TYPE=0

# Filled after deriving API credentials. Leave blank until generated.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
